# Copy this file to .env and fill in your keys.
# .env is gitignored; this template holds NO real values and is safe to commit.

# Groq — LLM that parses prompts, selects venues, and interprets swaps.
GROQ_API_KEY=

# Google Maps Platform keys (can be one key reused across APIs, or one per API).
# Places API (New) — venue search AND city/address geocoding (/api/geocode
# reuses this key via Text Search; no separate Geocoding API key needed)
GOOGLE_PLACES_API_KEY=
# Routes API — transit / walk legs
GOOGLE_ROUTES_API_KEY=
# Weather API — hourly forecast
GOOGLE_WEATHER_API_KEY=
# Maps JavaScript API — browser map tiles (the only key exposed to the browser)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
